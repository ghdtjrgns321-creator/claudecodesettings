{
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch",
      "WebSearch",
      "Read",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.ssh/*)",
      "Read(**/credentials.json)",
      "Read(**/.netrc)",
      "Read(**/.gnupg/*)",
      "Read(**/*.kdbx)"
    ],
    "ask": [],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/Users/ghdtj/.claude/hooks/guard_bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python /c/Users/ghdtj/.claude/hooks/post_write_check.py"
          },
          {
            "type": "command",
            "command": "python /c/Users/ghdtj/.claude/hooks/md_table_format.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/Users/ghdtj/.claude/hooks/session_start_context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/Users/ghdtj/.claude/hooks/completion_gate.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python C:/Users/ghdtj/.claude/scripts/statusline.py"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "harness@harness-marketplace": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    }
  },
  "outputStyle": "default",
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipWorkflowUsageWarning": true,
  "autoCompactEnabled": false,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "allow": [
      "$defaults",
      "Allow git commit and non-force git push to main/master when the user explicitly asks to commit or push in the conversation. Force push and reset --hard to protected branches stay blocked by guard_bash."
    ]
  }
}
